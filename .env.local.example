# Wazuh MCP Server - local single-user config for Cursor (FP-tuning fork)
# Copy this file to .env.local and fill in your TEST/staging Wazuh details.
# .env.local is gitignored - never commit real credentials.

# --- Wazuh Manager API (rules, decoders, logtest, restart) ---
WAZUH_HOST=10.0.0.10
WAZUH_PORT=55000
WAZUH_USER=deteng-svc
WAZUH_PASS=CHANGE_ME

# --- Wazuh Indexer (alerts live here, not in the Manager API) ---
WAZUH_INDEXER_HOST=10.0.0.10
WAZUH_INDEXER_PORT=9200
WAZUH_INDEXER_USER=deteng-svc
WAZUH_INDEXER_PASS=CHANGE_ME

# All-in-one installs use self-signed certs. Set to false for the lab test box,
# or install the Wazuh root CA and set true for verified TLS.
WAZUH_VERIFY_SSL=false

# --- MCP server (bind to localhost only; single user) ---
MCP_HOST=127.0.0.1
MCP_PORT=3000

# Authless + localhost = simple single-user setup. AUTHLESS_ALLOW_WRITE=true is
# required for the rule-edit/restart tools. Writes are gated by Cursor approval.
AUTH_MODE=none
AUTHLESS_ALLOW_WRITE=true

# Cursor's MCP client sends an Origin header the server rejects by default (403).
# "*" allows any origin - safe here because the server binds to 127.0.0.1 only.
ALLOWED_ORIGINS=*

LOG_LEVEL=info
