# Atomic Red Team MCP Server example configuration.
# Copy to .env.atomic.local and fill in values for the isolated Windows test VM.

ATOMIC_MCP_HOST=127.0.0.1
ATOMIC_MCP_PORT=3001

# hyperv_direct is recommended when the Windows test VM runs on local Hyper-V.
# Use winrm for PowerShell Remoting over HTTPS on an isolated host-only network.
ATOMIC_TRANSPORT=hyperv_direct
ATOMIC_TARGET_HOST=windowsTest
ATOMIC_VM_NAME=windowsTest
ATOMIC_WAZUH_AGENT_NAME=windowsTest
ATOMIC_SNAPSHOT_NAME=atomic-clean
ATOMIC_ATOMICS_PATH=C:\AtomicRedTeam\atomics
ATOMIC_MAX_RUNTIME_SECONDS=600
ATOMIC_OUTPUT_LIMIT_BYTES=128000

# Keep write disabled by default. Set true only when you are ready for Cursor
# to see detonation/snapshot tools, then leave those tools off Cursor's allowlist
# so every run still requires explicit approval.
ATOMIC_AUTHLESS_ALLOW_WRITE=false

# Required only when ATOMIC_TRANSPORT=winrm. Store real secrets only in .env.atomic.local.
ATOMIC_WINRM_USERNAME=
ATOMIC_WINRM_PASSWORD=
ATOMIC_WINRM_PORT=5986
ATOMIC_WINRM_VERIFY_TLS=true
# Optional. Omit to let the executor try negotiate then ntlm (same as pypsrp default).
# ATOMIC_WINRM_AUTH=negotiate
# Optional. Omit to auto-prefix local accounts as .\username
# ATOMIC_WINRM_DOMAIN=.

ATOMIC_LEDGER_PATH=tools/redteam/ledger.jsonl
ATOMIC_COVERAGE_PATH=tools/redteam/coverage.md
